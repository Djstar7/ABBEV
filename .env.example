APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Comptes de test OTP (review Play Store) : OTP non envoyé par email,
# code fixe ci-dessous accepté. Laisser vide pour désactiver.
OTP_TEST_EMAILS=
OTP_TEST_CODE=123456

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------
#  Paiements
# ------------------------------------------------------------------

# PayPal (abonnement + tickets, web/Android).
# Voir config/paypal.php (package srmklive/paypal) pour les noms exacts.

# KPay — Mobile Money (Orange Money / MTN MoMo), abonnement + tickets.
# Noms tels que lus par config/services.php + config/kpay.php.
KPAY_BASE_URL=https://admin.kpay.site
KPAY_API_KEY=
KPAY_SECRET_KEY=
KPAY_GATEWAY_SECRET=
KPAY_MAX_DURATION=300

# NOWPayments — paiement crypto (BTC, ETH, USDT…), abonnement + tickets.
# Les credentials se gèrent depuis le dashboard (Configuration → Crypto).
# L'IPN crypto (source de vérité) arrive sur /api/webhooks/nowpayments, signé
# en HMAC-SHA512 (header x-nowpayments-sig).
#   - En PROD : laisser le champ « URL callback » vide → APP_URL est utilisée.
#     APP_URL doit être l'URL publique HTTPS du backend.
#   - En DEV  : exposer le backend (ngrok) et renseigner l'URL ngrok dans
#     Configuration → Crypto → « URL callback » (nowpayments_callback_url).
#     Ex : https://xxxx.ngrok-free.dev  (le chemin /api/webhooks/nowpayments
#     est ajouté automatiquement).

# FreeMoPay (optionnel, abonnement). Voir config/freemopay.php.

# Apple In-App Purchase (abonnement iOS uniquement — App Store Server API).
# bundle_id doit correspondre au PRODUCT_BUNDLE_IDENTIFIER iOS (com.abbev.abbev).
# issuer_id / key_id / private_key proviennent de App Store Connect →
# Users and Access → Integrations → In-App Purchase (clé .p8).
APPLE_IAP_BUNDLE_ID=com.abbev.abbev
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
# Coller le contenu du .p8 (avec \n) OU pointer APPLE_IAP_KEY_PATH vers le fichier.
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_KEY_PATH=
# true tant que l'abonnement n'est pas approuvé en prod. Le service tente
# sandbox puis prod en fallback, donc une valeur erronée n'est pas bloquante.
APPLE_IAP_SANDBOX=true

VITE_APP_NAME="${APP_NAME}"
